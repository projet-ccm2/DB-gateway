generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id       String  @id @default(uuid()) @map("User_ID") @db.VarChar(36)
  username String  @map("User_Username") @db.VarChar(50)

  // relations
  achieved   Achieved[]  @relation("user_achieved")
  are        Are[]       @relation("user_are")
  possesses  Possesses[] @relation("user_possesses")

  @@map("Users")
}

model Chanel {
  id   String @id @default(uuid()) @map("Chanel_ID") @db.Char(36)
  name String @map("Chanel_Name") @db.VarChar(50)

  achievements Achievement[]
  badges       Badge[]
  are          Are[] @relation("chanel_are")

  @@map("Chanels")
}

model TypeAchievement {
  id    String @id @default(uuid()) @map("Type_ID") @db.Char(36)
  label String @map("Type_Label") @db.VarChar(50)
  data  String @map("Type_Data") @db.VarChar(55)

  achievements Achievement[]

  @@map("Type_Achievements")
}

model Achievement {
  id          String  @id @default(uuid()) @map("Achievement_ID") @db.Char(36)
  title       String  @map("Achievement_Title") @db.VarChar(50)
  description String  @map("Achievement_Description") @db.VarChar(255)
  goal        Int     @map("Achievement_Goal")
  reward      Int     @map("Achievement_Reward")
  label       String  @map("Achievement_Label") @db.VarChar(55)
  public      Boolean @map("Achievement_Public")
  downloads   Int     @map("Achievement_Downloads")
  visits      Int     @map("Achievement_Visits")
  active      Boolean @map("Achievement_Active")
  secret      Boolean @map("Achievement_Secret")
  image       String  @map("Achievement_Image") @db.VarChar(55)

  chanelId String? @map("Chanel_ID") @db.Char(36)
  typeId   String? @map("Type_ID")   @db.Char(36)

  chanel Chanel? @relation(fields: [chanelId], references: [id])
  type   TypeAchievement? @relation(fields: [typeId], references: [id])

  achieved Achieved[]

  @@map("Achievements")
}

model Badge {
  id      String @id @default(uuid()) @map("Badge_ID") @db.VarChar(36)
  title   String @map("Badge_Title") @db.VarChar(50)
  img     String @map("Badge_img") @db.VarChar(50)

  chanelId String? @map("Chanel_ID") @db.Char(36)
  chanel   Chanel? @relation(fields: [chanelId], references: [id])

  possesses Possesses[]

  @@map("Badges")
}

model Achieved {
  achievementId String   @map("Achievement_ID") @db.Char(36)
  userId        String   @map("User_ID")        @db.VarChar(36)
  count         Int      @map("Count")
  finished      Boolean  @map("Finished")
  labelActive   Boolean  @map("Label_Active")
  aquiredDate   DateTime @map("Aquired_Date")

  user        User        @relation("user_achieved", fields: [userId], references: [id])
  achievement Achievement @relation(fields: [achievementId], references: [id])

  @@id([achievementId, userId])
  @@map("_Achieved")
}

model Are {
  userId   String @map("User_ID") @db.VarChar(36)
  chanelId String @map("Chanel_ID") @db.Char(36)
  userType String @map("User_Type") @db.VarChar(50)

  user   User   @relation("user_are", fields: [userId], references: [id])
  chanel Chanel @relation("chanel_are", fields: [chanelId], references: [id])

  @@id([userId, chanelId])
  @@map("_Are")
}

model Possesses {
  userId      String   @map("User_ID") @db.VarChar(36)
  badgeId     String   @map("Badge_ID") @db.VarChar(36)
  aquiredDate DateTime @map("Aquired_Date")

  user  User  @relation("user_possesses", fields: [userId], references: [id])
  badge Badge @relation(fields: [badgeId], references: [id])

  @@id([userId, badgeId])
  @@map("_Possesses")
}
