{
  "name": "db-gateway",
  "version": "1.0.0",
  "description": "",
  "homepage": "https://github.com/projet-ccm2/DB-gateway#readme",
  "bugs": {
    "url": "https://github.com/projet-ccm2/DB-gateway/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/projet-ccm2/DB-gateway.git"
  },
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "dev:db": "docker compose --env-file .env -f docker-compose.yml up --build -d",
    "dev:db:down": "docker compose --env-file .env -f docker-compose.yml down -v",
    "dev": "npm run dev:db && npm run start",
    "build": "tsc",
    "start": "node dist/index.js",
    "test:db": "docker compose --env-file .env.test -f docker-compose.test.yml up --build -d && npx wait-port localhost:3307 -t 30000",
    "test:db:down": "docker compose --env-file .env.test -f docker-compose.test.yml down -v",
  "test:unit": "npx prisma generate && jest --runInBand src/tests/unit",
  "test:server": "npx prisma generate && jest --runInBand src/tests/unit/server.unit.test.ts",
  "test:integration": "npx prisma generate && npm run test:db && jest --runInBand src/tests/integration && npm run test:db:down",
  "test": "npx prisma generate && npm run test:db && jest --runInBand && npm run test:db:down",
    "prettier": "npx prettier . --write",
    "db:init": "npx prisma generate && npx prisma db push && ts-node src/prisma/seed.ts",
    "init:all": "docker compose --env-file .env.test -f docker-compose.test.yml up --build -d && npx wait-port localhost:3307 -t 30000 && node scripts/dbInit.js",
    "server:start": "ts-node src/server.ts",
  "test:coverage": "npx prisma generate && jest --runInBand --coverage src/tests/unit",
  "test:coverage:full": "npx prisma generate && jest --runInBand --coverage"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.7.2",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^61.4.1",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^29.7.0",
    "prettier": "^3.6.2",
    "prisma": "^7.0.1",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "wait-port": "^1.1.0"
  },
  "dependencies": {
    "@prisma/client": "^7.0.1",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "mysql2": "^3.15.2",
    "winston": "^3.18.3"
  }
}
