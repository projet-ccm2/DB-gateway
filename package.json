{
  "name": "db-gateway",
  "version": "1.0.0",
  "description": "",
  "homepage": "https://github.com/projet-ccm2/DB-gateway#readme",
  "bugs": {
    "url": "https://github.com/projet-ccm2/DB-gateway/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/projet-ccm2/DB-gateway.git"
  },
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "dev:db": "docker compose --env-file .env -f docker-compose.yml up --build -d",
    "dev:db:down": "docker compose --env-file .env -f docker-compose.yml down -v",
    "dev": "npm run dev:db && npm run start",
    "test:db": "docker compose --env-file .env.test -f docker-compose.test.yml up --build -d",
    "test:db:down": "docker compose --env-file .env.test -f docker-compose.test.yml down -v",
    "test:env": "npm run test:db && npm run start",
    "build": "tsc",
    "start": "node dist/index.js",
    "prettier": "npx prettier . --write",
    "test": "jest --testPathPattern='src/' --runInBand --coverage --coverageReporters=lcov --passWithNoTests",
    "test:coverage": "jest --testPathPattern='src/' --runInBand --coverage --coverageReporters=text --coverageReporters=lcov --coverageReporters=json --passWithNoTests",
    "test:watch": "jest --testPathPattern='src/' --watch --coverage --passWithNoTests",
    "test:ci": "jest --testPathPattern='src/' --runInBand --coverage --coverageReporters=lcov --coverageReporters=json --ci --watchAll=false --passWithNoTests"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.7.2",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^57.0.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^29.7.0",
    "prettier": "^3.6.2",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "mysql2": "^3.15.2",
    "winston": "^3.18.3"
  }
}
