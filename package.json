{
  "name": "db-gateway",
  "version": "1.0.0",
  "description": "",
  "homepage": "https://github.com/projet-ccm2/DB-gateway#readme",
  "bugs": {
    "url": "https://github.com/projet-ccm2/DB-gateway/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/projet-ccm2/DB-gateway.git"
  },
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "prisma:gen": "prisma generate",
    "dev:db": "docker compose --env-file .env -f docker-compose.yml up --build -d",
    "dev:db:down": "docker compose --env-file .env -f docker-compose.yml down -v",
    "dev": "npm run dev:db && npm run start",
    "build": "tsc",
    "start": "node dist/index.js",
    "test:unit": "jest --config jest.unit.config.mjs --runInBand",
    "test:server": "jest --config jest.unit.config.mjs --runInBand src/tests/unit/server.unit.test.ts",
    "test:integration": "jest --config jest.integration.config.mjs --runInBand",
    "test": "jest --config jest.unit.config.mjs --runInBand && jest --config jest.integration.config.mjs --runInBand",
    "prettier": "npx prettier . --write",
    "db:init": "npx prisma db push && ts-node src/prisma/seed.ts",
    "server:start": "ts-node src/index.ts",
    "test:coverage": "jest --runInBand --coverage src/tests/unit",
    "test:coverage:full": "jest --runInBand --coverage"
  },
  "devDependencies": {
    "@testcontainers/mysql": "^11.9.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.7.2",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^61.4.1",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^29.7.0",
    "prettier": "^3.6.2",
    "prisma": "^6.19.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "mysql2": "^3.15.2",
    "winston": "^3.18.3"
  }
}
